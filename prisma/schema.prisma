// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model News {
  id        Int      @id @default(autoincrement())
  title     String   @db.VarChar(255)
  date      String   @db.VarChar(100)
  category  String   @db.VarChar(100)
  excerpt   String   @db.Text
  image     String?  @db.VarChar(1024) // Relative path to public/uploads
  content   String?  @db.LongText    // Detailed news body
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("news")
}

model EmployeeHonor {
  id          Int      @id @default(autoincrement())
  month       String   @db.VarChar(50)
  year        String   @db.VarChar(20)
  image       String?  @db.VarChar(1024) 
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("employee_honors")
}

model CarouselSlide {
  id        Int      @id @default(autoincrement())
  image     String   @db.VarChar(1024) // Path to the uploaded image
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("carousel_slides")
}

model OrgChart {
  id         Int      @id @default(autoincrement())
  department String   @db.VarChar(255)
  image      String?  @db.VarChar(1024) 
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("org_charts")
}
